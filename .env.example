# ---- Client (bundled, safe to expose) ----
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ---- Server only (serverless functions; NEVER exposed to the client) ----
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LLM providers. ANTHROPIC is required (default draft model). Others are optional/free.
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Used only by scripts/create-user.mjs (the one-time login provisioning)
NEW_USER_EMAIL=
NEW_USER_PASSWORD=
